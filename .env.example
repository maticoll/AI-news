OPENAI_API_KEY=your_key_here
REFRESH_SECRET_TOKEN=choose_a_random_secret
NEWSLETTER_SENDERS=sender1@example.com,sender2@example.com
DATABASE_URL=sqlite:///./ainews.db
CATEGORIES_PATH=./categories.json

# Gmail auth — choose one:
# Option A: cloud/production — paste the full content of gmail_token.json as a single-line JSON string
GMAIL_TOKEN_JSON=
# Option B: local development — path to token file (used if GMAIL_TOKEN_JSON is not set)
GMAIL_TOKEN_PATH=./gmail_token.json
